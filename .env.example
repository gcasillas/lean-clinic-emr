# Copy to .env and customize for each clinic deployment.
# Keep this file free of plaintext credentials.

CLINIC_PROFILE=primary-care
PROJECT_ID=your-gcp-project
REGION=us-central1

DATASET_ID=clinic-dataset
FHIR_STORE_ID=clinic-fhir
BUNDLE_PATH=phase1-sandbox/data/fhir_bundle.json

SERVICE_NAME=clinic-openemr
SQL_INSTANCE=clinic-openemr-sql
CLOUD_SQL_TIER=db-custom-1-3840
CLOUD_RUN_IMAGE=openemr/openemr:latest

MYSQL_DATABASE=openemr
MYSQL_PORT=3306

SECRET_DB_USER=openemr-db-user
SECRET_DB_PASS=openemr-db-pass
SECRET_DB_ROOT_PASS=openemr-db-root-pass

MANUAL_SETUP=yes
ALLOW_UNAUTHENTICATED=yes
OPENEMR_SMOKE_ENDPOINT=/apis/default/api/

# For web installer only, use Cloud SQL public IP (temporary) if required:
# INSTALL_DB_TCP_HOST=
